{
  "name": "remotion-mcp",
  "version": "1.0.3",
  "description": "MCP server for AI-powered Remotion video creation — render videos, stills, and GIFs directly from your AI assistant",
  "main": "dist/index.js",
  "bin": {
    "remotion-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,0o755);console.log('Added shebang to dist/index.js');\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MCP_MODE=http node dist/index.js",
    "test": "npx tsx tests/smoke.ts"
  },
  "keywords": [
    "mcp",
    "remotion",
    "video",
    "ai",
    "model-context-protocol",
    "animation"
  ],
  "author": "dotlasher",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vidhanvyrs/remotion-mcp"
  },
  "homepage": "https://github.com/Vidhanvyrs/remotion-mcp#readme",
  "bugs": {
    "url": "https://github.com/Vidhanvyrs/remotion-mcp/issues"
  },
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@remotion/bundler": "4.0.462",
    "@remotion/renderer": "4.0.462",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "remotion": "4.0.462",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
